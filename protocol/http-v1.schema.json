{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://herdr.example/protocol/http-v1.schema.json",
  "title": "Herdr Remote same-origin HTTP API v1",
  "x-endpoints": {
    "session": {"method":"GET","path":"/api/v1/session","origin_required":false,"csrf_required":false,"request":null,"responses":{"200":"#/$defs/sessionResponse"}},
    "csrf": {"method":"GET","path":"/api/v1/csrf","origin_required":false,"csrf_required":false,"request":null,"responses":{"200":"#/$defs/csrfResponse"}},
    "action_status": {"method":"GET","path":"/api/v1/actions/{action_id}","origin_required":false,"csrf_required":false,"request":null,"responses":{"200":"#/$defs/actionStatusResponse"}},
    "enrollment_create": {"method":"POST","path":"/api/v1/enrollments","origin_required":true,"csrf_required":true,"request":"#/$defs/enrollmentRequest","responses":{"201":"#/$defs/enrollmentResponse"}},
    "host_credential_delete": {"method":"DELETE","path":"/api/v1/hosts/{host_id}/credential","origin_required":true,"csrf_required":true,"request":null,"responses":{"204":"#/$defs/emptyResponse"}},
    "push_register": {"method":"POST","path":"/api/v1/push/subscriptions","origin_required":true,"csrf_required":true,"request":"#/$defs/pushSubscription","responses":{"204":"#/$defs/emptyResponse"}},
    "push_reconcile": {"method":"POST","path":"/api/v1/push/subscriptions/reconcile","origin_required":true,"csrf_required":true,"request":"#/$defs/endpointRequest","responses":{"200":"#/$defs/reconcileResponse"}},
    "push_replace": {"method":"POST","path":"/api/v1/push/subscriptions/replace","origin_required":true,"csrf_required":true,"request":"#/$defs/replaceRequest","responses":{"204":"#/$defs/emptyResponse"}},
    "push_delete": {"method":"DELETE","path":"/api/v1/push/subscriptions","origin_required":true,"csrf_required":true,"request":"#/$defs/endpointsRequest","responses":{"204":"#/$defs/emptyResponse"}},
    "push_test_enabled": {"method":"POST","path":"/api/v1/push/test","origin_required":true,"csrf_required":true,"request":"#/$defs/emptyRequest","responses":{"202":"#/$defs/pushEnabledResponse"}},
    "push_test_disabled": {"method":"POST","path":"/api/v1/push/test","origin_required":true,"csrf_required":true,"request":"#/$defs/emptyRequest","responses":{"200":"#/$defs/pushDisabledResponse"}},
    "logout": {"method":"POST","path":"/auth/logout","origin_required":true,"csrf_required":true,"request":"#/$defs/emptyRequest","responses":{"200":"#/$defs/logoutResponse"}}
  },
  "$defs": {
    "endpoint": {"type":"string","format":"uri","pattern":"^https://[A-Za-z0-9.-]*[A-Za-z][A-Za-z0-9.-]*(?::443)?(?:[/?][^#\\s]*)?$","minLength":9,"maxLength":2048},
    "emptyRequest": {"type":"object","additionalProperties":false,"properties":{}},
    "emptyResponse": {"type":"null"},
    "sessionResponse": {
      "type":"object","additionalProperties":false,"required":["authenticated","operator","push_public_key","logout_url"],
      "properties":{"authenticated":{"const":true},"operator":{"type":"object","additionalProperties":false,"required":["display_name"],"properties":{"display_name":{"type":"string","minLength":1,"maxLength":256}}},"push_public_key":{"type":["string","null"],"pattern":"^[A-Za-z0-9_-]{87}$"},"logout_url":{"type":"string","format":"uri","pattern":"^https://[^/@?#\\s]+(?:[/?][^#\\s]*)?$","minLength":9,"maxLength":2048}}
    },
    "csrfResponse": {"type":"object","additionalProperties":false,"required":["token"],"properties":{"token":{"type":"string","minLength":32,"maxLength":128,"pattern":"^[A-Za-z0-9_-]+$"}}},
    "actionStatusResponse": {"type":"object","additionalProperties":false,"required":["action_id","operation_type","status","code","requested_at","completed_at"],"properties":{"action_id":{"type":"string","format":"uuid"},"operation_type":{"type":"string","enum":["agent.read","agent.send_text","agent.send_keys","agent.send_input","agent.interrupt","prompt.respond"]},"status":{"type":"string","enum":["succeeded","rejected","failed","unknown"]},"code":{"type":["string","null"],"maxLength":64},"requested_at":{"type":"string","format":"date-time"},"completed_at":{"type":"string","format":"date-time"}}},
    "enrollmentRequest": {"type":"object","additionalProperties":false,"required":["display_name"],"properties":{"display_name":{"type":"string","minLength":1,"maxLength":80,"pattern":"^[^\\x00-\\x1F\\x7F-\\x9F]+$"}}},
    "enrollmentResponse": {"type":"object","additionalProperties":false,"required":["token","host_id","expires_at"],"properties":{"token":{"type":"string","pattern":"^[0-9a-f]{64}$"},"host_id":{"type":"string","format":"uuid"},"expires_at":{"type":"string","format":"date-time"}}},
    "pushKeys": {"type":"object","additionalProperties":false,"required":["p256dh","auth"],"properties":{"p256dh":{"type":"string","minLength":1,"maxLength":512},"auth":{"type":"string","minLength":1,"maxLength":256}}},
    "pushSubscription": {"type":"object","additionalProperties":false,"required":["endpoint","keys"],"properties":{"endpoint":{"$ref":"#/$defs/endpoint"},"keys":{"$ref":"#/$defs/pushKeys"}}},
    "endpointRequest": {"type":"object","additionalProperties":false,"required":["endpoint"],"properties":{"endpoint":{"$ref":"#/$defs/endpoint"}}},
    "endpointsRequest": {"type":"object","additionalProperties":false,"required":["endpoints"],"properties":{"endpoints":{"type":"array","minItems":1,"maxItems":17,"uniqueItems":true,"items":{"$ref":"#/$defs/endpoint"}}}},
    "replaceRequest": {"type":"object","additionalProperties":false,"required":["source_endpoints","subscription"],"properties":{"source_endpoints":{"type":"array","minItems":1,"maxItems":16,"uniqueItems":true,"items":{"$ref":"#/$defs/endpoint"}},"subscription":{"$ref":"#/$defs/pushSubscription"}}},
    "reconcileResponse": {"type":"object","additionalProperties":false,"required":["subscribed"],"properties":{"subscribed":{"type":"boolean"}}},
    "pushEnabledResponse": {"type":"object","additionalProperties":false,"required":["enabled"],"properties":{"enabled":{"const":true}}},
    "pushDisabledResponse": {"type":"object","additionalProperties":false,"required":["enabled"],"properties":{"enabled":{"const":false}}},
    "logoutResponse": {"type":"object","additionalProperties":false,"required":["logout_url"],"properties":{"logout_url":{"type":"string","format":"uri","pattern":"^https://[^/@?#\\s]+(?:[/?][^#\\s]*)?$","minLength":9,"maxLength":2048}}}
  }
}
