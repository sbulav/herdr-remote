# Get from @BotFather on Telegram
HERDI_TG_TOKEN=your-bot-token-here

# Send /start to your bot, it will print your chat ID
HERDI_TG_CHAT_ID=your-chat-id

# Relay WebSocket address (default: local)
HERDI_RELAY_WS=ws://127.0.0.1:8375

# Remote herdr instances (comma-separated SSH targets)
# Requires passwordless SSH (key-based auth)
HERDI_REMOTES=user@server1,user@server2
