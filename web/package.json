{
  "name": "herdr-remote-web",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=22.0.0"
  },
  "scripts": {
    "dev": "vite",
    "generate:protocol": "node scripts/generate-protocol-validator.mjs",
    "build": "npm run typecheck && vite build",
    "typecheck": "npm run generate:protocol && tsc --noEmit --pretty false -p tsconfig.app.json && tsc --noEmit --pretty false -p tsconfig.node.json",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:e2e": "playwright test",
    "test:e2e:nix": "bash scripts/run-playwright-nix.sh",
    "verify:ci": "npm run typecheck && npm test && npm run build",
    "verify": "npm run typecheck && npm test && npm run build && npm run test:e2e",
    "verify:nix": "npm run typecheck && npm test && npm run build && npm run test:e2e:nix",
    "preview": "vite preview"
  },
  "dependencies": {
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "vite-plugin-pwa": "1.0.1",
    "workbox-core": "7.3.0",
    "workbox-precaching": "7.3.0",
    "workbox-routing": "7.3.0"
  },
  "devDependencies": {
    "@playwright/test": "1.59.1",
    "@testing-library/jest-dom": "6.6.3",
    "@testing-library/react": "16.3.0",
    "@testing-library/user-event": "14.6.1",
    "@types/node": "22.20.1",
    "@types/react": "19.1.8",
    "@types/react-dom": "19.1.6",
    "@vitejs/plugin-react": "4.6.0",
    "ajv": "8.20.0",
    "ajv-formats": "3.0.1",
    "axe-core": "4.10.3",
    "jsdom": "26.1.0",
    "typescript": "5.8.3",
    "vite": "6.4.3",
    "vitest": "3.2.7"
  }
}
